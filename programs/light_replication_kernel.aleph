probe_Φ(healed_child)
probe_Ω(healed_child)
let g0 = palace(3) mediate(vav, mediate(vav, aleph, mem), shin)
let g1 = mediate(vav, g0, g0)
let g2 = mediate(aleph, g1, shin)
