d(replica1, replica2)
d(replica2, system())
palace(3) replica1
palace(3) replica2
tier(replica2)
probe_Φ(replica2)
probe_Ω(replica2)
let base_light = palace(3) mediate(vav, mediate(vav, aleph, mem), shin)
let anomalous = mediate(vav, kuf, base_light)
