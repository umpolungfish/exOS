let healed_child = palace(4) mediate(shin, kernel, kuf)
let self_healed = mediate(vav, p3, p3)
let shin_p3 = mediate(shin, p3, p3)
let mem_p3 = mediate(mem, p3, p3)
d(p3, healed_child)
d(p3, self_healed)
d(p3, shin_p3)
d(p3, mem_p3)
